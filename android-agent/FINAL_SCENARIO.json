  "actions": [
    {
      "id": "step_01_proxy",
      "type": "setup_proxy",
      "proxy": "random",
      "description": "Шаг 1: Установка случайного SOCKS5 прокси"
    },
    {
      "id": "step_02_detect_location",
      "type": "detect_proxy_location",
      "description": "Шаг 2: Определение геолокации прокси"
    },
    {
      "id": "step_03_timezone",
      "type": "change_timezone",
      "timezone": "auto",
      "description": "Шаг 3: Установка таймзоны на основе прокси"
    },
    {
      "id": "step_04_location",
      "type": "change_location",
      "latitude": "auto",
      "longitude": "auto",
      "description": "Шаг 4: Подмена геолокации"
    },
    {
      "id": "step_05_locale",
      "type": "change_locale",
      "locale": "en_US",
      "description": "Шаг 5: Установка английского языка"
    },
    {
      "id": "step_06_clear",
      "type": "clear_webview_data",
      "description": "Шаг 6: Очистка данных браузера"
    },
    {
      "id": "step_07_google",
      "type": "open_url",
      "url": "https://www.google.com",
      "wait_ms": 3000,
      "description": "Шаг 7: Открытие Google"
    },
    {
      "id": "step_08_search",
      "type": "google_search",
      "query": "site:pickuplineinsider.com",
      "wait_ms": 5000,
      "description": "Шаг 8: Поиск в Google"
    },
    {
      "id": "step_09_screenshot_search",
      "type": "take_screenshot",
      "filename": "google_search_results",
      "upload_to_server": true,
      "wait_before_ms": 3000,
      "description": "Шаг 9: Скриншот результатов поиска"
    },
    {
      "id": "step_10_click_result",
      "type": "click_search_result",
      "result_index": "random",
      "wait_ms": 5000,
      "description": "Шаг 10: Клик по случайной ссылке"
    },
    {
      "id": "step_11_screenshot_page1",
      "type": "take_screenshot",
      "filename": "page_1",
      "upload_to_server": true,
      "wait_before_ms": 3000,
      "description": "Шаг 11: Скриншот страницы 1"
    },
    {
      "id": "step_12_browse1",
      "type": "browse_page",
      "scroll": true,
      "scroll_count": 2,
      "stay_time_ms": 3000,
      "description": "Шаг 12: Просмотр страницы 1"
    },
    {
      "id": "step_13_click_internal1",
      "type": "click_internal_link",
      "link_index": "random",
